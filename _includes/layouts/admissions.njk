---
layout: base.njk
---
<section id="admissions">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="eyebrow">Абітурыентам</div>
      <h2>Як паступіць</h2>
    </div>
    <div class="current-intake reveal">
      <h3>Бягучы набор</h3>
      <p>Рэгістрацыя кандыдатаў: <strong>{{ current_intake.registration_dates }}</strong>.<br>Уступны экзамен: <strong>{{ current_intake.exam_date }}</strong>, па адрасе г. Мінск, праезд Галадзеда, 15В.</p>
      <a href="{{ registration_url }}" class="btn btn-primary" style="margin-top:14px;">Анлайн-рэгістрацыя</a>
    </div>
    <div class="admissions-grid reveal">
      <div class="info-card">
        <h3>Дакументы для паступлення</h3>
        <ul>
          {% for doc in documents %}
          <li>{{ doc.item }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="info-card">
        <h3>Уступны экзамен</h3>
        <ul>
          {% for exam_item in exam_items %}
          <li>{{ exam_item.item }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>
