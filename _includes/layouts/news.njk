---
layout: base.njk
---
<section id="news">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="eyebrow">Навіны</div>
      <h2>Навіны і падзеі</h2>
    </div>
    <div class="news-list reveal" id="news-list">
      {% for item in collections.news %}
      <a href="{{ item.url }}" class="news-item" data-index="{{ loop.index0 }}">
        {% if item.data.photo %}
        <img class="news-thumb" src="{{ item.data.photo }}" alt="">
        {% elif item.data.thumbnail %}
        <img class="news-thumb" src="data:image/svg+xml;base64," alt="">
        {% endif %}
        <div class="news-body">
          <span class="news-date">{{ item.data.date | readableDate }}</span>
          <h3>{{ item.data.title }}</h3>
          <p>{{ item.data.excerpt | newsExcerpt(item.data.body) }}</p>
          <span class="news-read-more">Чытаць далей →</span>
        </div>
      </a>
      {% endfor %}
    </div>
    <button class="show-more-btn" id="news-more">Паказаць больш</button>
    <script>
      (function(){
        const items = Array.from(document.querySelectorAll('#news-list .news-item[data-index]'));
        const btn = document.getElementById('news-more');
        const pageSize = 6;
        let shown = pageSize;

        function render(){
          items.forEach(it=>{
            const i = parseInt(it.dataset.index, 10);
            it.style.display = i < shown ? '' : 'none';
          });
          btn.style.display = shown >= items.length ? 'none' : '';
        }
        btn.addEventListener('click', ()=>{ shown += pageSize; render(); });
        render();
      })();
    </script>
  </div>
</section>
