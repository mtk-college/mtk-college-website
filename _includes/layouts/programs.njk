---
layout: base.njk
---
<section id="programs">
  <div class="wrap">
    <div class="section-head reveal">
      <div class="eyebrow">Навучанне</div>
      <h2>Напрамкі навучання</h2>
    </div>
    <div class="programs-grid reveal">
      <div class="program-card">
        <div class="icon-ring"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h7a3 3 0 013 3v13a3 3 0 00-3-3H4z"/><path d="M20 4h-7a3 3 0 00-3 3v13a3 3 0 013-3h7z"/></svg></div>
        <h3>{{ groups[0].name }}</h3>
        <p>{{ groups[0].description }}</p>
      </div>
      <div class="program-card">
        <div class="icon-ring"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="7" r="3.5"/><path d="M5 21v-2a7 7 0 0114 0v2"/></svg></div>
        <h3>{{ groups[1].name }}</h3>
        <p>{{ groups[1].description }}</p>
      </div>
      <div class="program-card">
        <div class="icon-ring"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
        <h3>{{ groups[2].name }}</h3>
        <p>{{ groups[2].description }}</p>
      </div>
      <div class="program-card">
        <div class="icon-ring"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><path d="M12 19v4"/><path d="M8 23h8"/></svg></div>
        <h3>{{ groups[3].name }}</h3>
        <p>{{ groups[3].description }}</p>
      </div>
      <div class="program-card">
        <div class="icon-ring"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><polygon points="16,8 13,13 8,16 11,11"/></svg></div>
        <h3>{{ groups[4].name }}</h3>
        <p>{{ groups[4].description }}</p>
      </div>
      <div class="program-card">
        <div class="icon-ring"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 13V6a1.5 1.5 0 013 0v6M11 12V4a1.5 1.5 0 013 0v8M14 13V6a1.5 1.5 0 013 0v7"/><path d="M5 13v3a6 6 0 006 6h2a6 6 0 006-6v-2"/></svg></div>
        <h3>{{ groups[5].name }}</h3>
        <p>{{ groups[5].description }}</p>
      </div>
    </div>

    <div class="subjects-block">
      <span class="subjects-label">Агульная праграма</span>
      <div class="subjects-grid">
        {% for subject in common_subjects %}
        <span>{{ subject.subject }}</span>
        {% endfor %}
      </div>
      <p class="subjects-note">Гэтыя прадметы вывучаюць усе студэнты, незалежна ад абранай групы.</p>
    </div>

    <div class="subjects-block">
      <span class="subjects-label">Профільныя прадметы</span>
      <div class="profile-list">
        {% for ps in profile_subjects %}
        <div class="profile-item"><span class="profile-subject">{{ ps.subject }}</span><span class="profile-group">{{ ps.group }}</span></div>
        {% endfor %}
      </div>
      <p class="subjects-note">Гэтыя прадметы дадаюцца на 3-м і 4-м курсах у залежнасці ад абранай групы навучання.</p>
    </div>

    <div class="subjects-block">
      <span class="subjects-label">Выкладчыкі</span>
      <div class="teachers-grid">
        {% for teacher in collections.teachers %}
        <div class="teacher-card">
          <div class="teacher-avatar"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" fill="none" stroke="var(--bordeaux)" stroke-width="1"/><path d="M12 6v12M7 9h10" stroke="var(--gold)" stroke-width="1.3"/></svg></div>
          <h4>{{ teacher.data.display_name }}</h4>
          <p class="teacher-subject">{% for s in teacher.data.subjects %}{{ s.subject }}{% if not loop.last %}, {% endif %}{% endfor %}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="cta-band" id="apply">
  <svg class="hero-bg-motif" viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 200 L60 140 C90 110 110 110 140 140 L180 100 C210 70 230 70 260 100 L300 60 C330 30 350 30 400 60" stroke="#faf7f0" stroke-width="3"/>
  </svg>
  <div class="wrap cta-band-inner">
    <h2>Адчуваеце пакліканне?</h2>
    <p>Запрашаем да навучання ўсіх свецкіх вернікаў ад 18 гадоў, хто шукае паглыбіць веру розумам і служыць людзям.</p>
    <div class="btn-row">
      <a href="/admissions.html" class="btn btn-primary">Умовы паступлення</a>
      <a href="/contacts.html" class="btn btn-ghost">Звязацца з намі</a>
    </div>
  </div>
</section>
